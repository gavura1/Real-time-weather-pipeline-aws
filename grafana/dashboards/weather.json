{
    "title": "Weather Pipeline",
    "uid": "weather-pipeline",
    "schemaVersion": 36,
    "version": 1,
    "refresh": "15s",
    "panels": [
        {
            "id": 1,
            "title": "Total HTTP Requests",
            "type": "stat",
            "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4},
            "targets": [{"expr": "sum(http_requests_total)", "legendFormat": "Total Requests"}]
        },
        {
            "id": 2,
            "title": "Requests per Endpoint",
            "type": "timeseries",
            "gridPos": { "x": 6, "y": 0, "w": 18, "h": 8},
            "targets": [{"expr": "rate(http_requests_total[1m])", "legendFormat": "{{endpoint}}"}]
        },
        {
            "id": 3,
            "title": "Cache Source Distributor",
            "type": "piechart",
            "gridPos": { "x": 0, "y": 4, "w": 6, "h": 8},
            "targets": [{"expr": "sum by (source) (weather_cache_source_total)", "legendFormat": "{{source}}"}]
        },
        {
            "id": 4,
            "title": "Requests Duration (p95)",
            "type": "timeseries",
            "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8},
            "targets": [{"expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, endpoint))", "legendFormat": "p95 {{endpoint}}"}]
        },
        {
            "id": 5,
            "title": "Requests Duration (p50)",
            "type": "timeseries",
            "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8},
            "targets": [{"expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, endpoint))", "legendFormat": "p50 {{endpoint}}"}]
        }
    ] 
}